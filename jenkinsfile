pipeline {
    agent any

    environment {
        SONAR_TOKEN = credentials('sonar-token')
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/ByteDeva/zomato-devsecops-clone.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('sonar') {
                        bat """
                        ${scannerHome}\\bin\\sonar-scanner.bat ^
                        -Dsonar.projectKey=zomato-clone ^
                        -Dsonar.sources=. ^
                        -Dsonar.host.url=http://localhost:9000 ^
                        -Dsonar.login=%SONAR_TOKEN%
                        """
                    }
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                bat '''
                C:\\tools\\dependency-check\\bin\\dependency-check.bat ^
                --project zomato ^
                --scan . ^
                --format HTML ^
                --out .
                '''
                archiveArtifacts artifacts: 'dependency-check-report.html', allowEmptyArchive: true
            }
        }

        stage('Build App') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t devadocker335/zomato-clone .'
            }
        }

        stage('Trivy Scan (HTML Report)') {
            steps {
                bat '''
                trivy image -f html -o trivy-report.html devadocker335/zomato-clone
                '''
                archiveArtifacts artifacts: 'trivy-report.html', allowEmptyArchive: true
            }
        }

        stage('Docker Push') {
            steps {
                bat 'docker push devadocker335/zomato-clone'
            }
        }

        stage('Deploy Container') {
            steps {
                bat '''
                docker stop zomato-container || exit 0
                docker rm zomato-container || exit 0
                docker run -d -p 3000:3000 --name zomato-container devadocker335/zomato-clone
                '''
            }
        }
    }

    post {
        success {
            echo "✅ FULL DevSecOps Pipeline Completed Successfully!"
        }
        failure {
            echo "❌ Pipeline failed! Check logs."
        }
    }
}