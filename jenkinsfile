pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/ByteDeva/zomato-devsecops-clone.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('sonar') {
                        bat "${scannerHome}\\bin\\sonar-scanner.bat"
                    }
                }
            }
        }

        stage('Build App') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t devadocker335/zomato-clone .'
            }
        }

        stage('Docker Push') {
            steps {
                bat 'docker push devadocker335/zomato-clone'
            }
        }

        stage('Deploy Container') {
            steps {
                bat '''
                docker stop zomato-container || true
                docker rm zomato-container || true
                docker run -d -p 3000:3000 --name zomato-container devadocker335/zomato-clone
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed!"
        }
    }
}